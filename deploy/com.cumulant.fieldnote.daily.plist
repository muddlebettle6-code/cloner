<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Continuous newsroom watcher (launchd, macOS). Runs scripts/news-watch.sh on an
  interval: each cycle scans for a significant breaking event and, when one
  clears the bar, researches + writes + auto-publishes a deep article on it.

  Install:
    cp deploy/com.cumulant.fieldnote.daily.plist ~/Library/LaunchAgents/
    launchctl load ~/Library/LaunchAgents/com.cumulant.fieldnote.daily.plist
  Uninstall:
    launchctl unload ~/Library/LaunchAgents/com.cumulant.fieldnote.daily.plist

  Adjust the paths, the run time (StartCalendarInterval), and PATH below to your
  machine. No API key is needed: generation uses your logged-in `claude` CLI
  (Claude Code), so make sure its directory (~/.local/bin) is on the PATH below.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cumulant.fieldnote.daily</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/aryanpatel/cloner/scripts/news-watch.sh</string>
    </array>

    <!-- Scan for a breaking event every hour. Lower to 1800 (30 min) to be
         quicker on scoops, or use scripts/daily-article.sh + StartCalendarInterval
         for a once-a-day piece instead of the continuous watcher. -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>EnvironmentVariables</key>
    <dict>
        <key>FCRI_DIR</key><string>/Users/aryanpatel/Desktop/cumulant/FCRI</string>
        <key>SITE_DIR</key><string>/Users/aryanpatel/cloner</string>
        <!-- The Cloudflare-served repo (built site is synced + pushed here). -->
        <key>FIELDNOTE_DEPLOY_DIR</key><string>/Users/aryanpatel/Downloads/Virtu_Fortuna_Project/cumulant</string>
        <!-- For RELIABLE unattended publishing, paste a GitHub PAT with
             Contents:write on the cumulant repo. Left blank, it falls back to
             your keychain credentials, which may not work from a background job. -->
        <key>GITHUB_TOKEN</key><string></string>
        <!-- Include the locations of node, python, and the claude CLI. -->
        <key>PATH</key><string>/Users/aryanpatel/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/aryanpatel/cloner/scripts/daily-article.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/aryanpatel/cloner/scripts/daily-article.err.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
